{
  "name": "@kerjacus/project-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "dev:temporal": "node --import tsx src/workers/temporal-worker.ts",
    "start:temporal": "node --import tsx src/workers/temporal-worker.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.7.0",
    "@kerjacus/config": "workspace:*",
    "@kerjacus/db": "workspace:*",
    "@kerjacus/logger": "workspace:*",
    "@kerjacus/nats-events": "workspace:*",
    "@kerjacus/shared": "workspace:*",
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1",
    "@opentelemetry/api": "^1.9.1",
    "@react-pdf/renderer": "^4.5.1",
    "@scalar/hono-api-reference": "^0.10.19",
    "@temporalio/activity": "^1.16.2",
    "@temporalio/client": "^1.16.2",
    "@temporalio/worker": "^1.16.2",
    "@temporalio/workflow": "^1.16.2",
    "cockatiel": "^3.2.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuidv7": "^1.0.0",
    "xstate": "^5.28.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^1.30.1",
    "@opentelemetry/core": "^1.30.1",
    "@types/react": "^19.2.15",
    "bun-types": "^1.3.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
